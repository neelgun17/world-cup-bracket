{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "includeFiles": "{wc_sim,web}/**", "maxLambdaSize": "30mb" }
    },
    { "src": "web/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/static/(.*)", "dest": "/web/$1" },
    { "src": "/favicon.ico", "status": 204 },
    { "src": "/(.*)", "dest": "/api/index.py" }
  ]
}
